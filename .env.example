# ── Postgres ─────────────────────────────────────────────────────────────────
# Password for the default `postgres` superuser. The `litellm` database is
# created automatically on first start via POSTGRES_DB.
POSTGRES_PASSWORD=change_me_strong_password

# ── LiteLLM ──────────────────────────────────────────────────────────────────
# Master key for the LiteLLM proxy API (used as the OpenAI API key in Open WebUI)
# Must start with "sk-"
LITELLM_MASTER_KEY=sk-change_me

# ── GitHub Copilot ───────────────────────────────────────────────────────────
# A GitHub OAuth token for an account with an active Copilot subscription.
#
# How to get it:
#   Option A – GitHub CLI (recommended):
#     brew install gh          # macOS
#     gh auth login            # follow the browser OAuth flow
#     gh auth token            # prints the token — paste it below
#
#   Option B – Personal Access Token (classic):
#     https://github.com/settings/tokens/new
#     Required scopes: (no extra scopes needed; Copilot access is tied to your subscription)
#     Note: Fine-grained tokens do not work with the Copilot API.
#
# LiteLLM exchanges this for short-lived Copilot session tokens automatically.
# The session tokens are cached in the `copilot_cache` Docker volume.
GITHUB_COPILOT_TOKEN=ghp_your_token_here
